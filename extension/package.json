{
  "name": "reviewflow",
  "displayName": "ReviewFlow — GitLab Code Reviews",
  "description": "Review code where you write it. IDE-native GitLab merge request workspace for Cursor and VS Code — draft comments, review sessions, and publish to GitLab without leaving the editor.",
  "version": "0.1.0",
  "publisher": "LuyandaLia",
  "author": {
    "name": "Luyanda Gcabo",
    "email": "Liagcabo@gmail.com",
    "url": "https://github.com/LuyandaLia"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuyandaLia/reviewflow.git"
  },
  "homepage": "https://github.com/LuyandaLia/reviewflow#readme",
  "bugs": {
    "url": "https://github.com/LuyandaLia/reviewflow/issues"
  },
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "keywords": [
    "reviewflow",
    "gitlab",
    "code review",
    "merge request",
    "pull request",
    "mr",
    "cursor",
    "vscode",
    "ide",
    "scm",
    "diff",
    "draft comments",
    "developer tools",
    "open source"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onView:reviewflow.repositories",
    "onCommand:reviewflow.addGitLabInstance",
    "onCommand:reviewflow.addRepository",
    "onCommand:reviewflow.addDraftComment",
    "onCommand:reviewflow.refreshRepositories",
    "onCommand:reviewflow.createReviewSession",
    "onCommand:reviewflow.publishDraftComment",
    "onCommand:reviewflow.publishReviewSession",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "reviewflow",
          "title": "ReviewFlow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "reviewflow": [
        {
          "id": "reviewflow.repositories",
          "name": "Repositories"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "reviewflow.repositories",
        "contents": "Cannot connect to the ReviewFlow backend.\n[Retry](command:reviewflow.retryConnection)",
        "when": "reviewflow.backendAvailable == false"
      },
      {
        "view": "reviewflow.repositories",
        "contents": "No GitLab instances registered.\n[Add GitLab Instance](command:reviewflow.addGitLabInstance)\n\nOnce you have an instance, you can register repositories.",
        "when": "reviewflow.backendAvailable && !reviewflow.hasInstances"
      }
    ],
    "commands": [
      {
        "command": "reviewflow.retryConnection",
        "title": "ReviewFlow: Retry Connection",
        "icon": "$(refresh)"
      },
      {
        "command": "reviewflow.addGitLabInstance",
        "title": "ReviewFlow: Add GitLab Instance",
        "icon": "$(add)"
      },
      {
        "command": "reviewflow.removeGitLabInstance",
        "title": "ReviewFlow: Remove GitLab Instance",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.addRepository",
        "title": "ReviewFlow: Add Repository",
        "icon": "$(add)"
      },
      {
        "command": "reviewflow.removeRepository",
        "title": "ReviewFlow: Remove Repository",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.refreshRepositories",
        "title": "ReviewFlow: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "reviewflow.addDraftComment",
        "title": "ReviewFlow: Add Draft Comment"
      },
      {
        "command": "reviewflow.editDraftComment",
        "title": "ReviewFlow: Edit Draft Comment",
        "icon": "$(edit)"
      },
      {
        "command": "reviewflow.removeDraftComment",
        "title": "ReviewFlow: Remove Comment",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.createReviewSession",
        "title": "ReviewFlow: New Review Session",
        "icon": "$(add)"
      },
      {
        "command": "reviewflow.renameReviewSession",
        "title": "ReviewFlow: Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "reviewflow.deleteReviewSession",
        "title": "ReviewFlow: Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.activateReviewSession",
        "title": "ReviewFlow: Set as Active Session",
        "icon": "$(circle-filled)"
      },
      {
        "command": "reviewflow.publishDraftComment",
        "title": "ReviewFlow: Publish Comment to GitLab",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "reviewflow.publishReviewSession",
        "title": "ReviewFlow: Publish Session to GitLab",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "reviewflow.syncReviewSession",
        "title": "ReviewFlow: Sync Session with GitLab",
        "icon": "$(sync)"
      },
      {
        "command": "reviewflow.suggestAiComments",
        "title": "ReviewFlow: AI Suggest Comments",
        "icon": "$(hubot)"
      },
      {
        "command": "reviewflow.acceptAiSuggestion",
        "title": "ReviewFlow: Accept AI Suggestion",
        "icon": "$(check)"
      },
      {
        "command": "reviewflow.dismissAiSuggestion",
        "title": "ReviewFlow: Dismiss AI Suggestion",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.saveInlineDraft",
        "title": "Save Draft",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "reviewflow.publishInlineComment",
        "title": "Publish",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "reviewflow.cancelInlineComposer",
        "title": "Cancel"
      },
      {
        "command": "reviewflow.cycleSeverity",
        "title": "Severity",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "reviewflow.editInlineComment",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "reviewflow.deleteInlineComment",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.publishReviewComment",
        "title": "Publish",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "reviewflow.copyInlineComment",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "reviewflow.acceptInlineAiSuggestion",
        "title": "Accept",
        "icon": "$(check)"
      },
      {
        "command": "reviewflow.dismissInlineAiSuggestion",
        "title": "Dismiss",
        "icon": "$(trash)"
      },
      {
        "command": "reviewflow.changeMrIid",
        "title": "ReviewFlow: Change MR IID"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "reviewflow.addGitLabInstance",
          "when": "view == reviewflow.repositories",
          "group": "navigation@1"
        },
        {
          "command": "reviewflow.addRepository",
          "when": "view == reviewflow.repositories && reviewflow.hasInstances",
          "group": "navigation@2"
        },
        {
          "command": "reviewflow.refreshRepositories",
          "when": "view == reviewflow.repositories",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "reviewflow.removeGitLabInstance",
          "when": "view == reviewflow.repositories && viewItem == gitlabInstance",
          "group": "inline"
        },
        {
          "command": "reviewflow.removeRepository",
          "when": "view == reviewflow.repositories && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "reviewflow.createReviewSession",
          "when": "view == reviewflow.repositories && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "reviewflow.activateReviewSession",
          "when": "view == reviewflow.repositories && viewItem == reviewSession",
          "group": "inline"
        },
        {
          "command": "reviewflow.renameReviewSession",
          "when": "view == reviewflow.repositories && (viewItem == reviewSession || viewItem == reviewSessionActive)",
          "group": "inline"
        },
        {
          "command": "reviewflow.deleteReviewSession",
          "when": "view == reviewflow.repositories && (viewItem == reviewSession || viewItem == reviewSessionActive)",
          "group": "inline"
        },
        {
          "command": "reviewflow.publishReviewSession",
          "when": "view == reviewflow.repositories && (viewItem == reviewSession || viewItem == reviewSessionActive)",
          "group": "inline"
        },
        {
          "command": "reviewflow.syncReviewSession",
          "when": "view == reviewflow.repositories && (viewItem == reviewSession || viewItem == reviewSessionActive)",
          "group": "inline"
        },
        {
          "command": "reviewflow.suggestAiComments",
          "when": "view == reviewflow.repositories && (viewItem == reviewSession || viewItem == reviewSessionActive)",
          "group": "inline"
        },
        {
          "command": "reviewflow.publishDraftComment",
          "when": "view == reviewflow.repositories && (viewItem == draftComment || viewItem == draftCommentFailed)",
          "group": "inline"
        },
        {
          "command": "reviewflow.editDraftComment",
          "when": "view == reviewflow.repositories && (viewItem == draftComment || viewItem == draftCommentFailed)",
          "group": "inline"
        },
        {
          "command": "reviewflow.removeDraftComment",
          "when": "view == reviewflow.repositories && (viewItem == draftComment || viewItem == draftCommentFailed || viewItem == draftCommentPublished)",
          "group": "inline"
        },
        {
          "command": "reviewflow.acceptAiSuggestion",
          "when": "view == reviewflow.repositories && viewItem == draftCommentAi",
          "group": "inline@1"
        },
        {
          "command": "reviewflow.dismissAiSuggestion",
          "when": "view == reviewflow.repositories && viewItem == draftCommentAi",
          "group": "inline@2"
        }
      ],
      "editor/context": [
        {
          "command": "reviewflow.addDraftComment",
          "group": "reviewflow@1"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "reviewflow.cycleSeverity",
          "group": "navigation@1",
          "when": "commentController == reviewflow"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "reviewflow.saveInlineDraft",
          "group": "inline@1",
          "when": "commentController == reviewflow && !commentIsEmpty"
        },
        {
          "command": "reviewflow.publishInlineComment",
          "group": "inline@2",
          "when": "commentController == reviewflow && !commentIsEmpty"
        },
        {
          "command": "reviewflow.cancelInlineComposer",
          "group": "inline@3",
          "when": "commentController == reviewflow"
        }
      ],
      "comments/comment/title": [
        {
          "command": "reviewflow.editInlineComment",
          "group": "navigation@1",
          "when": "commentController == reviewflow && comment == editable"
        },
        {
          "command": "reviewflow.publishReviewComment",
          "group": "navigation@2",
          "when": "commentController == reviewflow && (comment == editable || comment == failed)"
        },
        {
          "command": "reviewflow.copyInlineComment",
          "group": "navigation@3",
          "when": "commentController == reviewflow"
        },
        {
          "command": "reviewflow.deleteInlineComment",
          "group": "navigation@4",
          "when": "commentController == reviewflow && comment != published"
        },
        {
          "command": "reviewflow.acceptInlineAiSuggestion",
          "group": "navigation@1",
          "when": "commentController == reviewflow && comment == aiSuggestion"
        },
        {
          "command": "reviewflow.dismissInlineAiSuggestion",
          "group": "navigation@2",
          "when": "commentController == reviewflow && comment == aiSuggestion"
        }
      ],
      "commandPalette": [
        {
          "command": "reviewflow.saveInlineDraft",
          "when": "false"
        },
        {
          "command": "reviewflow.publishInlineComment",
          "when": "false"
        },
        {
          "command": "reviewflow.cancelInlineComposer",
          "when": "false"
        },
        {
          "command": "reviewflow.cycleSeverity",
          "when": "false"
        },
        {
          "command": "reviewflow.editInlineComment",
          "when": "false"
        },
        {
          "command": "reviewflow.deleteInlineComment",
          "when": "false"
        },
        {
          "command": "reviewflow.publishReviewComment",
          "when": "false"
        },
        {
          "command": "reviewflow.copyInlineComment",
          "when": "false"
        },
        {
          "command": "reviewflow.acceptInlineAiSuggestion",
          "when": "false"
        },
        {
          "command": "reviewflow.dismissInlineAiSuggestion",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "reviewflow.saveInlineDraft",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "commentController == reviewflow && commentFocused && !commentIsEmpty"
      },
      {
        "command": "reviewflow.cancelInlineComposer",
        "key": "escape",
        "when": "commentController == reviewflow && commentFocused"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "stage-backend": "node scripts/stage-backend.mjs",
    "unstage-backend": "node scripts/unstage-backend.mjs",
    "package": "npm run stage-backend && npm run compile && vsce package --no-dependencies && npm run unstage-backend"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
